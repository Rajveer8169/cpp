class Solution {
public:
    int singleNonDuplicate(vector<int>& nums) {
        int left = 0;
        int right = nums.size() - 1;

        while (left < right) {
            int mid = left + (right - left) / 2;

            // Make mid even so that it points to the first
            // element of a potential pair
            if (mid % 2 == 1) {
                mid--;
            }

            // If the pair is valid, the single element
            // must be in the right half
            if (nums[mid] == nums[mid + 1]) {
                left = mid + 2;
            }
            // Pair pattern breaks, so the single element
            // lies at mid or in the left half
            else {
                right = mid;
            }
        }

        return nums[left];
    }
};

/*
Time Complexity: O(log n)

- We use Binary Search.
- In each iteration, the search space is reduced by half.
- Therefore, the number of iterations is log₂(n).

Space Complexity: O(1)

- Only a few variables (left, right, mid) are used.
- No extra data structures are created.
*/
