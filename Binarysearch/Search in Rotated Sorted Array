class Solution {
public:
    int search(vector<int>& nums, int target) {
        int low = 0;
        int high = nums.size() - 1;

        while (low <= high) {
            int mid = low + (high - low) / 2;

            if (nums[mid] == target) {
                return mid;
            }

            // Left half is sorted
            if (nums[low] <= nums[mid]) {

                // Target lies in the left sorted half
                if (target >= nums[low] && target < nums[mid]) {
                    high = mid - 1;
                }
                // Target lies in the right half
                else {
                    low = mid + 1;
                }
            }
            // Right half is sorted
            else {

                // Target lies in the right sorted half
                if (target > nums[mid] && target <= nums[high]) {
                    low = mid + 1;
                }
                // Target lies in the left half
                else {
                    high = mid - 1;
                }
            }
        }

        return -1;
    }
};

/*
Time Complexity: O(log n)

- In each iteration, we discard half of the search space.
- This is a standard Binary Search.
- Total iterations = log₂(n).

Space Complexity: O(1)

- Only a few variables (low, high, mid) are used.
- No extra data structures are created.
*/
