// Pattern: Two Pointers
// Time Complexity: O(n²)
// Space Complexity: O(1)

class Solution {
public:
    int threeSumClosest(vector<int>& nums, int target) {

        // Sort array for two pointer approach
        sort(nums.begin(), nums.end());

        int n = nums.size();

        // Initialize closest sum with first 3 elements
        int closeSum = nums[0] + nums[1] + nums[2];

        // Fix one element
        for(int i = 0; i < n - 2; i++) {

            // Two pointers
            int left = i + 1;
            int right = n - 1;

            // Find best pair for current i
            while(left < right) {

                // Current triplet sum
                int currSum = nums[i] + nums[left] + nums[right];

                // Update answer if current sum is closer
                if(abs(target - currSum) < abs(target - closeSum)) {
                    closeSum = currSum;
                }

                // Exact target found
                if(currSum == target) {
                    return currSum;
                }

                // Need bigger sum
                else if(currSum < target) {
                    left++;
                }

                // Need smaller sum
                else {
                    right--;
                }
            }
        }

        // Return closest sum
        return closeSum;
    }
};
